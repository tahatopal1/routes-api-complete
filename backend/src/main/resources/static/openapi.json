  "components": {
    "schemas": {
      "LocationReferenceDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "locationType": {
            "type": "string",
            "enum": [
              "AIRPORT",
              "VENUE"
            ],
            "minLength": 1
          }
        },
        "required": [
          "id",
          "locationType"
        ]
      },
      "TransportationRequestDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "origin": {
            "$ref": "#/components/schemas/LocationReferenceDto"
          },
          "destination": {
            "$ref": "#/components/schemas/LocationReferenceDto"
          },
          "transportationType": {
            "type": "string",
            "enum": [
              "FLIGHT",
              "BUS",
              "SUBWAY",
              "UBER"
            ]
          },
          "opDays": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "required": [
          "destination",
          "origin",
          "transportationType"
        ]
      },
      "LocationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "locationName": {
            "type": "string",
            "maxLength": 100,
            "minLength": 3,
            "pattern": "^[a-zA-Z ]+$"
          },
          "locationCode": {
            "type": "string",
            "maxLength": 10,
            "minLength": 3,
            "pattern": "^[A-Z]+$"
          },
          "country": {
            "type": "string",
            "maxLength": 60,
            "minLength": 3,
            "pattern": "^[a-zA-Z ]+$"
          },
          "city": {
            "type": "string",
            "maxLength": 100,
            "minLength": 3,
            "pattern": "^[a-zA-Z ]+$"
          },
          "locationType": {
            "type": "string",
            "enum": [
              "AIRPORT",
              "VENUE"
            ]
          }
        },
        "required": [
          "city",
          "country",
          "locationCode",
          "locationName",
          "locationType"
        ]
      },
      "TransportationResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "origin": {
            "$ref": "#/components/schemas/LocationDto"
          },
          "destination": {
            "$ref": "#/components/schemas/LocationDto"
          },
          "transportationType": {
            "type": "string",
            "enum": [
              "FLIGHT",
              "BUS",
              "SUBWAY",
              "UBER"
            ]
          },
          "opDays": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      },
      "RouteRequestDto": {
        "type": "object",
        "properties": {
          "origin": {
            "$ref": "#/components/schemas/LocationReferenceDto"
          },
          "destination": {
            "$ref": "#/components/schemas/LocationReferenceDto"
          },
          "searchDate": {
            "type": "string",
            "format": "date"
          },
          "cacheKey": {
            "type": "string"
          }
        },
        "required": [
          "destination",
          "origin",
          "searchDate"
        ]
      },
      "RouteResponseDto": {
        "type": "object",
        "properties": {
          "itinerary": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransportationReferenceDto"
            }
          }
        }
      },
      "TransportationReferenceDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "origin": {
            "$ref": "#/components/schemas/LocationDto"
          },
          "destination": {
            "$ref": "#/components/schemas/LocationDto"
          },
          "transportationType": {
            "type": "string",
            "enum": [
              "FLIGHT",
              "BUS",
              "SUBWAY",
              "UBER"
            ]
          }
        }
      },
      "AuthRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 1
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "password",
          "username"
        ]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "TransportationSearchDto": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "transportationType": {
            "type": "string",
            "enum": [
              "FLIGHT",
              "BUS",
              "SUBWAY",
              "UBER"
            ]
          },
          "day": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "Pageable": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PageTransportationResponseDto": {
        "type": "object",
        "properties": {
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "first": {
            "type": "boolean"
          },
          "last": {
            "type": "boolean"
          },
          "numberOfElements": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransportationResponseDto"
            }
          },
          "number": {
            "type": "integer",
            "format": "int32"
          },
          "empty": {
            "type": "boolean"
          }
        }
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "paged": {
            "type": "boolean"
          },
          "pageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "unpaged": {
            "type": "boolean"
          },
          "offset": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "sorted": {
            "type": "boolean"
          },
          "unsorted": {
            "type": "boolean"
          },
          "empty": {
            "type": "boolean"
          }
        }
      },
      "LocationSearchDto": {
        "type": "object",
        "properties": {
          "locationName": {
            "type": "string"
          },
          "locationCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "locationType": {
            "type": "string"
          }
        }
      },
      "PageLocationDto": {
        "type": "object",
        "properties": {
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "first": {
            "type": "boolean"
          },
          "last": {
            "type": "boolean"
          },
          "numberOfElements": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LocationDto"
            }
          },
          "number": {
            "type": "integer",
            "format": "int32"
          },
          "empty": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "description": "JWT Cookie Authentication. Make sure to authenticate via /login first to receive the 'jwt' cookie.",
        "name": "jwt",
        "in": "cookie"
      }
    }
  }
}
