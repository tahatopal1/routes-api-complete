                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "transportation-controller"
        ],
        "operationId": "createTransportation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransportationRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
